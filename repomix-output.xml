<file path="blog/why-simple-tools-are-better.md">
---
title: Why Simple Tools Are Better
date: 2025-01-20
---

# Embracing Simplicity

After years of wrestling with complex build tools and frameworks, I've come to appreciate **simple, boring technology**.

## The Problem with Complexity

Modern web development often feels like this:

* Install 500 dependencies
* Wait 10 minutes for `npm install`
* Fight with webpack configs
* Deal with breaking changes every month

## A Better Way

What if we just used PHP? 

```
<?php
echo "Hello, world!";
?>
```

No build step. No transpilation. Just *code that runs*.

## Benefits

1. **Deploy anywhere** - Cheap shared hosting works fine
2. **No build time** - Edit and refresh
3. **Easy debugging** - No source maps needed
4. **Stable** - PHP hasn't changed much in 10 years

## Conclusion

Sometimes the old ways are the best ways. Not everything needs to be a single-page app with a complex build pipeline.

Keep it simple. Ship faster. Sleep better.
</file>

<file path="lib/Router.php">
<?php

// Router class
class Router {
    private $markdown;
    
    public function __construct() {
        $this->markdown = new SimpleMarkdown();
    }
    
    public function route() {
        $path = $this->getPath();
        
        // API routes
        if (strpos($path, '/api/') === 0) {
            return $this->handleAPI($path);
        }
        
        // Blog/markdown routes
        if (strpos($path, '/blog/') === 0) {
            return $this->handleBlog($path);
        }
        
        // Home page
        if ($path === '/' || $path === '') {
            return $this->handleHome();
        }

        // Generic pages (e.g. /about -> templates/about.php)
        if ($this->handleGenericPage($path)) {
            return;
        }
        
        // 404
        return $this->handle404();
    }

    private function handleGenericPage($path) {
        $slug = trim($path, '/');
        $slug = preg_replace('/[^a-zA-Z0-9_-]/', '', $slug); // Sanitize

        if (empty($slug)) return false;

        $templateFile = TEMPLATES_DIR . '/' . $slug . '.php';
        
        if (file_exists($templateFile)) {
            $this->renderTemplate($slug);
            return true;
        }

        return false;
    }
    
    private function getPath() {
        $path = $_SERVER['REQUEST_URI'] ?? '/';
        $path = parse_url($path, PHP_URL_PATH);
        $path = rtrim($path, '/');
        return $path ?: '/';
    }
    
    private function handleAPI($path) {
        // Extract API endpoint: /api/daily-js-data -> daily-js-data
        $endpoint = substr($path, 5); // Remove '/api/'
        
        // Sanitize endpoint name
        $endpoint = preg_replace('/[^a-zA-Z0-9_-]/', '', $endpoint);
        
        // Look for JSON file
        $jsonFile = API_DATA_DIR . '/' . $endpoint . '.json';
        
        if (!file_exists($jsonFile)) {
            http_response_code(404);
            header('Content-Type: application/json');
            echo json_encode(['error' => 'Endpoint not found']);
            return;
        }
        
        // Read and serve JSON
        $jsonData = file_get_contents($jsonFile);
        
        // Validate JSON
        json_decode($jsonData);
        if (json_last_error() !== JSON_ERROR_NONE) {
            http_response_code(500);
            header('Content-Type: application/json');
            echo json_encode(['error' => 'Invalid JSON data']);
            return;
        }
        
        // Set headers
        header('Content-Type: application/json');
        header('X-Content-Type-Options: nosniff');
        header('Access-Control-Allow-Origin: *'); // Remove if you want CORS protection
        
        if (CACHE_ENABLED) {
            header('Cache-Control: public, max-age=' . CACHE_TIME);
        }
        
        echo $jsonData;
    }
    
    private function handleBlog($path) {
        // Extract slug: /blog/my-post -> my-post
        $slug = substr($path, 6); // Remove '/blog/'
        
        // Sanitize slug
        $slug = preg_replace('/[^a-zA-Z0-9_-]/', '', $slug);
        
        // Look for markdown file
        $mdFile = BLOG_DIR . '/' . $slug . '.md';
        
        if (!file_exists($mdFile)) {
            return $this->handle404();
        }
        
        // Parse markdown
        $markdown = file_get_contents($mdFile);
        
        // Extract frontmatter (optional)
        $frontmatter = [];
        $content = $markdown;
        
        if (preg_match('/^---\s*\n(.*?)\n---\s*\n(.*)$/s', $markdown, $matches)) {
            // Parse YAML-like frontmatter
            $frontmatterText = $matches[1];
            $content = $matches[2];
            
            foreach (explode("\n", $frontmatterText) as $line) {
                if (preg_match('/^(\w+):\s*(.+)$/', $line, $m)) {
                    $frontmatter[trim($m[1])] = trim($m[2]);
                }
            }
        }
        
        // Convert markdown to HTML
        $html = $this->markdown->text($content);
        
        // Load template
        $this->renderTemplate('blog', [
            'title' => $frontmatter['title'] ?? ucwords(str_replace('-', ' ', $slug)),
            'content' => $html,
            'date' => $frontmatter['date'] ?? '',
            'slug' => $slug
        ]);
    }
    
    private function handleHome() {
        // Get list of blog posts
        $posts = [];
        if (is_dir(BLOG_DIR)) {
            $files = glob(BLOG_DIR . '/*.md');
            foreach ($files as $file) {
                $slug = basename($file, '.md');
                $content = file_get_contents($file);
                
                // Extract frontmatter
                $title = ucwords(str_replace('-', ' ', $slug));
                $date = '';
                
                if (preg_match('/^---\s*\n(.*?)\n---/s', $content, $matches)) {
                    if (preg_match('/title:\s*(.+)$/m', $matches[1], $m)) {
                        $title = trim($m[1]);
                    }
                    if (preg_match('/date:\s*(.+)$/m', $matches[1], $m)) {
                        $date = trim($m[1]);
                    }
                }
                
                $posts[] = [
                    'slug' => $slug,
                    'title' => $title,
                    'date' => $date
                ];
            }
            
            // Sort by date (newest first)
            usort($posts, function($a, $b) {
                return strcmp($b['date'], $a['date']);
            });
        }
        
        $this->renderTemplate('home', ['posts' => $posts]);
    }
    
    private function handle404() {
        http_response_code(404);
        $this->renderTemplate('404', []);
    }
    
    private function renderTemplate($template, $data = []) {
        extract($data);
        
        $templateFile = TEMPLATES_DIR . '/' . $template . '.php';
        
        if (!file_exists($templateFile)) {
            // Fallback to simple output
            echo "Template not found: $template";
            return;
        }
        
        // Start output buffering to capture template content
        ob_start();
        require $templateFile;
        $content = ob_get_clean();
        
        // Determine layout (default to _layout.php, but allow override)
        $layout = $layout ?? '_layout';
        $layoutFile = TEMPLATES_DIR . '/' . $layout . '.php';
        
        if (file_exists($layoutFile)) {
            require $layoutFile;
        } else {
            // If no layout exists, just echo content
            echo $content;
        }
    }
}
</file>

