# Environment Configuration
# Copy this file to .env and configure for your environment

# Environment: development or production
ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# CORS Configuration
# Add allowed origins as comma-separated list
# Example: ALLOWED_ORIGINS=https://example.com,https://app.example.com
ALLOWED_ORIGINS=

# Proxy Configuration
# Only enable if behind a trusted reverse proxy (nginx, cloudflare, etc.)
TRUST_PROXY=false

# Cache Configuration
CACHE_ENABLED=true
CACHE_TIME=3600

# Site Configuration
SITE_TITLE=My Site
SITE_URL=https://example.com
SITE_DESCRIPTION=A simple PHP-powered blog
SITE_LANGUAGE=en-us

# RSS Feed Configuration
# Maximum number of recent posts to include in the RSS feed
RSS_MAX_ITEMS=20
